    {
      "name": "post",
      "label": "Blog Posts",
      "path": "content/posts",
      "format": "md",
      "ui": {
        "filename": {
          "readonly": false
        }
      },
      "fields": [
        {
          "type": "string",
          "name": "title",
          "label": "Title",
          "isTitle": true,
          "required": true,
          "namespace": [
            "post",
            "title"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "string",
          "name": "excerpt",
          "label": "Excerpt",
          "description": "A one-sentence summary shown on post cards and in SEO.",
          "required": true,
          "ui": {
            "component": "textarea"
          },
          "namespace": [
            "post",
            "excerpt"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "datetime",
          "name": "date",
          "label": "Publish Date",
          "required": true,
          "namespace": [
            "post",
            "date"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "string",
          "name": "category",
          "label": "Category",
          "description": "Choose the type of post.",
          "required": true,
          "options": [
            "Research to Practice",
            "Debate",
            "Hot Takes",
            "Expert Lens",
            "Myth Buster",
            "Innovation Spotlight"
          ],
          "namespace": [
            "post",
            "category"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "string",
          "name": "tags",
          "label": "Topics",
          "description": "Add topic labels freely. Examples: Foundations, Process, Conditions, AI.",
