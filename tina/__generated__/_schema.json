          "namespace": [
            "post",
            "tags"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "string",
          "name": "linkedInUrl",
          "label": "LinkedIn Post URL",
          "description": "Paste the URL for the LinkedIn version of this post.",
          "namespace": [
            "post",
            "linkedInUrl"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "boolean",
          "name": "featured",
          "label": "Featured Post",
          "namespace": [
            "post",
            "featured"
          ],
          "searchable": true,
          "uid": false
        },
        {
          "type": "rich-text",
          "name": "body",
          "label": "Content",
          "isBody": true,
          "namespace": [
            "post",
            "body"
          ],
          "searchable": true,
          "parser": {
            "type": "markdown"
          },
          "uid": false
        }
      ],
      "namespace": [
        "post"
      ]
